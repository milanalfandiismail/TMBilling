{
  "build": {
    "beforeBuildCommand": "npx tailwindcss@3 -i src/css/input.css -o src/css/output.css --minify",
    "beforeDevCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "TMBilling",
    "version": "1.4.5"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],


      "identifier": "com.tmbilling.app",
      "longDescription": "",
      "shortDescription": "",
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": true,
        "height": 700,
        "resizable": false,
        "title": "",
        "width": 1000,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "transparent": true
      }
    ],
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true
    }
  }
}
