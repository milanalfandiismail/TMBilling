# --- CORE SETTINGS ---
# Ganti dengan string random yang panjang untuk produksi
SECRET_KEY=your-super-secret-key-here
# Gunakan sqlite untuk dev, atau postgresql/mysql untuk production
DATABASE_URL=sqlite:///warnet.db
DEBUG_MODE=True

# --- SECURITY ---
# API Key untuk validasi request dari Client C# / C++
CLIENT_API_KEY=your-client-api-key-here

# --- BILLING & LOGIC ---
# Threshold untuk mendeteksi PC mati (menit)
BLACKOUT_THRESHOLD_MINUTES=3
# Interval client mengirim heartbeat ke server (detik)
POLLING_INTERVAL=5
# Waktu tunggu sebelum PC otomatis shutdown jika kosong (menit)
AUTO_SHUTDOWN_MINUTES=3

# --- LOGGING ---
# Lokasi penyimpanan file log sistem
LOG_FILE_PATH=logs/app.log
LOG_LEVEL=INFO

# --- PRODUCTION WSGI SERVER ---
# Jumlah concurrent threads untuk Waitress WSGI server (minimal 8 direkomendasikan)
WAITRESS_THREADS=8